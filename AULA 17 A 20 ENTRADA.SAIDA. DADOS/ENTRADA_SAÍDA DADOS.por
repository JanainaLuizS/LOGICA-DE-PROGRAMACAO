programa {
  funcao inicio() {

    
    cadeia nome 
    real salarioFixo
    real totalVendas
    real salarioFinal


    escreva("Digite o nome do vendedor: ")
     leia(nome)
    
    escreva("Digite o salário do vendedor: ")
    leia (salarioFixo)

    escreva("Digite Total de Vendas: ")
    leia (totalVendas)

    salarioFinal = salarioFixo + totalVendas* 0.15

    escreva ("Digite salario Final É ", salarioFinal ) 

    
    

    

    

    
  }
}
