programa {
  funcao real areaCirculo( real raio) { // na função retorno preciso colocar o tipo antes 

    real areaCirculo =  3.14 *(raio* raio)
    retorne areaCirculo

  }

  funcao inicio() {

    real resultado = areaCirculo ( 10.0)

    escreva ( " A área do circulo é : ", resultado) //




    
  }
}

94.Escreva uma função que receba o raio e retorne a área do círculo.