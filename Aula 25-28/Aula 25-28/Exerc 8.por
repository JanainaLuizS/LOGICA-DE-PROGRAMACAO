programa {
  funcao inicio() {

//input 
    real Dolar 
    real Real 
    real Cotacao

    escreva ("Valor Cotação Dolar: ")
    leia(Cotacao)

    escreva ("Valor Dolar: ")
    leia(Dolar)

// input - processamento

  Real= Cotacao * Dolar

// output

    escreva(" O valor convertido em real é: ", Real )
   

    
  }
}
