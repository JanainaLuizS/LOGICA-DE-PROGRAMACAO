programa {
  funcao inicio() {

    cadeia nome 
    real nota1 
    real nota2 
    real nota3
    real media

   escreva ("Digite seu nome: ")
   leia (nome)

   escreva("nota 1° prova: " )
   leia(nota1)

   escreva("nota 2° prova: ")
   leia(nota2)

   escreva("nota 3° prova: ")
   leia(nota3)


   media=(nota1+nota2+nota3)/3


   escreva( " O aluno ", nome, " tem média : ", media)



    
  }
}
